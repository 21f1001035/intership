# PostgreSQL
POSTGRES_USER=iitropar
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=iit_screening

# App
DATABASE_URL=postgresql://iitropar:CHANGE_THIS_STRONG_PASSWORD@db:5432/iit_screening
REDIS_URL=redis://redis:6379/0
